  "interfaces": [
    {
      "type": "bus", "direction": "slave", "protocol": "TL-UL", "port": "tl", "width": 32,
      "description": "TileLink-UL slave interface. 12 registers + 2 FIFO windows, 6-bit address width.",
      "signals": [
        {"name": "clk_i", "direction": "input", "type": "clock", "width": 1},
        {"name": "rst_ni", "direction": "input", "type": "reset", "width": 1, "active_level": "low"},
        {"name": "tl_i", "direction": "input", "type": "data", "width": 1, "description": "TL-UL host-to-device (tl_h2d_t)"},
        {"name": "tl_o", "direction": "output", "type": "data", "width": 1, "description": "TL-UL device-to-host (tl_d2h_t)"}
      ]
    },
    {
      "type": "serial", "direction": "master", "protocol": "SPI", "port": "cio",
      "description": "SPI master: SCK, CSB (NumCS lines), 4-bit SD (Standard/Dual/Quad).",
      "signals": [
        {"name": "cio_sck_o", "direction": "output", "type": "clock", "width": 1},
        {"name": "cio_sck_en_o", "direction": "output", "type": "control", "width": 1},
        {"name": "cio_csb_o", "direction": "output", "type": "control", "width": "NumCS"},
        {"name": "cio_csb_en_o", "direction": "output", "type": "control", "width": "NumCS"},
        {"name": "cio_sd_o", "direction": "output", "type": "data", "width": 4},
        {"name": "cio_sd_en_o", "direction": "output", "type": "control", "width": 4},
        {"name": "cio_sd_i", "direction": "input", "type": "data", "width": 4}
      ]
    },
    {
      "type": "interrupt", "direction": "output", "protocol": "level", "port": "intr", "width": 2,
      "description": "2 interrupts: error (6 error types) and spi_event (idle, ready, watermark).",
      "signals": [
        {"name": "intr_error_o", "direction": "output", "type": "interrupt", "width": 1},
        {"name": "intr_spi_event_o", "direction": "output", "type": "interrupt", "width": 1}
      ]
    }
  ],
  "parameters": [
    {"name": "NumCS", "type": "int", "default": 1, "description": "Number of chip select lines (up to 4 SPI slaves)"},
    {"name": "TxDepth", "type": "int", "default": 72, "description": "TX FIFO depth in bytes"},
    {"name": "RxDepth", "type": "int", "default": 64, "description": "RX FIFO depth in bytes"},
    {"name": "CmdDepth", "type": "int", "default": 4, "description": "Command queue depth"},
    {"name": "ByteOrder", "type": "logic", "default": 1, "description": "1=little-endian, 0=big-endian"},
    {"name": "EnableRacl", "type": "bit", "default": "1'b0", "description": "Enable RACL register access control"}
  ],
  "performance": {
    "spi_clock": "16-bit clock divider. At 50 MHz sys: up to 25 MHz SPI clock (div=1)",
    "spi_modes": "Standard (1-bit), Dual (2-bit), Quad (4-bit)",
    "throughput": "Quad mode at 25 MHz: 12.5 MB/s peak",
    "fifo": "TX 72-byte, RX 64-byte, Command queue 4 entries"
  },
  "architecture": {
    "type": "peripheral",
    "submodules": ["spi_host_core", "spi_host_fsm", "spi_host_data_fifos", "spi_host_command_queue", "spi_host_shift_register", "spi_host_byte_merge", "spi_host_byte_select", "spi_host_window", "spi_host_reg_top"],
    "features": [
      "Standard, Dual, and Quad SPI modes with per-segment configuration",
      "Multi-CS support (NumCS parameter, up to 4 slaves)",
      "Per-CS configurable timing: clock divider, CS idle/lead/trail, CPOL, CPHA, full-cycle mode",
      "Command queue (4 entries) with CSAAT for multi-segment transactions",
      "TX FIFO (72 bytes) + RX FIFO (64 bytes) with configurable watermarks",
      "6 error types: overflow, underflow, busy, cmd_inval, csid_inval, access_inval",
      "SPI passthrough mode for direct flash access (single CS only)",
      "Configurable byte order (little/big endian)",
      "Bus integrity checking with fatal alert",
      "Auto-generated register file (reggen) with 12 CSRs + 2 FIFO windows"
    ]
  },
  "dependencies": [
    {"name": "opentitan-prim", "type": "library", "description": "prim_alert_sender, prim_fifo_sync, prim_edge_detector, prim_subreg"},
